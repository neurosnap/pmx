#!/usr/bin/env bash
set -eo pipefail

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "help" ]; then
    cat <<HELPEOF
pmx — AI coding assistant powered by zmx sessions

Usage:
  pmx [options] [prompt ...]
  pmx [options] < input

Options:
  -e, --edit      Open a prompt in $EDITOR before running
  -h, --help      Show this help

Environment:
  ZMX_SESSION     Required. The zmx session to use.
  EDITOR          Editor for -e mode (default: vi)
  LLM_SYSTEM      Override the default system prompt

Examples:
  pmx "explain this code"
  pmx < some_file.txt
  pmx -e                    # write prompt in editor
HELPEOF
    exit 0
fi

if [ -z "$ZMX_SESSION" ]; then
    echo "pmx: ZMX_SESSION not set" >&2
    exit 1
fi

if [ "${1:-}" = "-e" ] || [ "${1:-}" = "--edit" ]; then
    tmpfile=$(mktemp /tmp/pmx-prompt.XXXXXX)
    "${EDITOR:-vi}" "$tmpfile"
    prompt=$(cat "$tmpfile")
    rm -f "$tmpfile"
    if [ -z "$prompt" ]; then
        echo "pmx: empty prompt, aborting" >&2
        exit 1
    fi
fi

if [ -z "${prompt:-}" ]; then
    if [ -t 0 ]; then
        if [ $# -gt 0 ]; then
            prompt="$*"
        else
            prompt=$(zmx history "$ZMX_SESSION" | tail -200)
        fi
    else
        saved_tty=$(stty -g </dev/tty 2>/dev/null || true)
        stdin_text=$(cat)
        exec 0</dev/tty
        [ -n "$saved_tty" ] && stty "$saved_tty" 2>/dev/null || true
        if [ $# -gt 0 ]; then
            prompt="${stdin_text}"$'\n\n'"$*"
        else
            prompt="$stdin_text"
        fi
    fi
fi

ctx add user "$prompt"

cyan=$'\e[36m'
green=$'\e[32m'
red=$'\e[31m'
dim=$'\e[2m'
reset=$'\e[0m'

printf "%s(tool output: zmx attach %s.tools)%s\n" "$cyan" "$ZMX_SESSION" "$reset" >&2
turn=0

while true; do
    turn=$((turn + 1))
    printf "%s--- turn %d ---%s\n" "$cyan" "$turn" "$reset" >&2

    calls=$(llm "$(ctx path)" "$(tool path)" | ctx add-assistant | tool) && rc=0 || rc=$?
    [ $rc -eq 2 ] && exit 1   # hard error
    [ $rc -eq 1 ] && break    # no tool calls — done

    while IFS= read -r call; do
        id=$(printf '%s' "$call" | jq -r '.id')
        name=$(printf '%s' "$call" | jq -r '.name')
        cmd=$(printf '%s' "$call" | jq -r '.cmd')
        t0=$(date +%s)000

        if [ "$name" = "write" ]; then
            file_path=$(printf '%s' "$call" | jq -r '.file_path')
            file_content=$(printf '%s' "$call" | jq -r '.content')
            printf "[%s] %s (%d bytes)\n" "$name" "$file_path" "${#file_content}" >&2
            mkdir -p "$(dirname "$file_path")"
            printf '%s' "$file_content" > "$file_path"
            printf '%s\n' "cat $file_path" | zmx run "$ZMX_SESSION.tools" >/dev/null 2>&1 || true
            printf "wrote %d bytes to %s\n" "${#file_content}" "$file_path" | ctx add-result "$id" "$name" || true
            code=$?
        elif [ "$name" = "edit" ]; then
            file_path=$(printf '%s' "$call" | jq -r '.file_path')
            num_edits=$(printf '%s' "$call" | jq '.edits | length')
            printf "[%s] %s (%d edits)\n" "$name" "$file_path" "$num_edits" >&2
            if [ ! -f "$file_path" ]; then
                printf "error: file not found: %s\n" "$file_path" | ctx add-result "$id" "$name" || true
                code=1
            else
                file_content=$(cat "$file_path")
                error_msg=""
                for i in $(seq 0 $((num_edits - 1))); do
                    old_text=$(printf '%s' "$call" | jq -r ".edits[$i].old_text")
                    count=$(printf '%s' "$file_content" | grep -cF "$old_text" || true)
                    if [ "$count" -eq 0 ]; then
                        old_preview=$(printf '%s' "$old_text" | tr '\n' ' ' | cut -c1-60)
                        error_msg="error: edit[$i] old_text not found in $file_path: \"$old_preview\""
                        break
                    elif [ "$count" -gt 1 ]; then
                        old_preview=$(printf '%s' "$old_text" | tr '\n' ' ' | cut -c1-60)
                        error_msg="error: edit[$i] old_text appears $count times in $file_path (must be unique): \"$old_preview\""
                        break
                    fi
                done
                if [ -n "$error_msg" ]; then
                    printf '%s\n' "$error_msg" | ctx add-result "$id" "$name" || true
                    code=1
                else
                    printf '%s' "$file_content" > "$file_path.orig"
                    for i in $(seq $((num_edits - 1)) -1 0); do
                        old_text=$(printf '%s' "$call" | jq -r ".edits[$i].old_text")
                        new_text=$(printf '%s' "$call" | jq -r ".edits[$i].new_text")
                        file_content="${file_content/"$old_text"/"$new_text"}"
                    done
                    printf '%s' "$file_content" > "$file_path"
                    printf '%s\n' "diff $file_path.orig $file_path; rm -f $file_path.orig" | zmx run "$ZMX_SESSION.tools" >/dev/null 2>&1 || true
                    printf "edited %s (%d edits applied)\n" "$file_path" "$num_edits" | ctx add-result "$id" "$name" || true
                    code=$?
                fi
            fi
        else
            cmd_preview=$(printf '%s' "$cmd" | tr '\n' ' ' | cut -c1-80)
            printf "[%s] %s\n" "$name" "$cmd_preview" >&2
            # Write command to temp file, run it as bash, then clean up
            script_file=$(mktemp /tmp/pmx-script.XXXXXX.sh)
            printf '%s\n' "$cmd" > "$script_file"
            zmx run "$ZMX_SESSION.tools" bash "$script_file" 2>&1 | ctx add-result "$id" "$name" || true
            code=${PIPESTATUS[0]}
            rm -f "$script_file"
        fi

        t1=$(date +%s)000
        if [ $code -eq 0 ]; then
            printf "%s=> exit %d%s  %dms\n" "$green" "$code" "$reset" "$((t1 - t0))" >&2
        else
            printf "%s=> exit %d%s  %dms\n" "$red" "$code" "$reset" "$((t1 - t0))" >&2
        fi
    done <<< "$calls"
    ctx stats >&2
done

printf "%s[done]%s\n" "$cyan" "$reset" >&2

if [ ! -t 1 ]; then
    ctx last-text
fi
